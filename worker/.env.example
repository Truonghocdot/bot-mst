WORKER_NAME=bot-mst-worker
WORKER_SOURCE=masothue
WORKER_MODE=rest

TARGET_URL=https://masothue.com/tra-cuu-ma-so-thue-doanh-nghiep-moi-thanh-lap
TARGET_LOGIN_URL=
TARGET_WS_URL=
TARGET_GRAPHQL_URL=
SITE_BASE_URL=https://masothue.com

# Browser identity / fingerprint
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
PLAYWRIGHT_STORAGE_STATE=.playwright/.auth/user.json
PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/141.0.0.0 Safari/537.36
PLAYWRIGHT_LOCALE=vi-VN
PLAYWRIGHT_TIMEZONE_ID=Asia/Ho_Chi_Minh
PLAYWRIGHT_VIEWPORT_WIDTH=1366
PLAYWRIGHT_VIEWPORT_HEIGHT=768

# Sticky/static proxy for Cloudflare / captcha bypass
PROXY_ENABLED=false
PROXY_TYPE=sticky_residential
PROXY_SERVER=
PROXY_FALLBACK_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_SESSION_ID=
PROXY_COUNTRY=VN

POLL_INTERVAL_MS=2000
MAX_ITEMS_PER_RUN=10
HTTP_TIMEOUT_MS=10000
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=2000

# Captcha / challenge bypass preparation
CAPTCHA_BYPASS_ENABLED=false
CAPTCHA_PROVIDER=capsolver
CAPTCHA_KIND=cloudflare_challenge
CAPTCHA_SITE_KEY=
CAPTCHA_PAGE_ACTION=
CAPTCHA_IS_ENTERPRISE=false

# CapSolver
CAPSOLVER_API_KEY=
CAPSOLVER_TASK_TYPE=AntiCloudflareTask
CAPSOLVER_CREATE_TASK_URL=https://api.capsolver.com/createTask
CAPSOLVER_GET_TASK_RESULT_URL=https://api.capsolver.com/getTaskResult
CAPSOLVER_USE_PROXY=true
CAPSOLVER_PROXY=
CAPSOLVER_USE_PLAYWRIGHT_PROXY=true
CAPSOLVER_USER_AGENT=
CAPSOLVER_SUBMIT_HTML=true
CAPSOLVER_POLL_INTERVAL_MS=3000
CAPSOLVER_TIMEOUT_MS=120000

CORE_API_BASE_URL=http://127.0.0.1:8000
CORE_API_ENDPOINT=/api/ingestions/masothue
CORE_API_TOKEN=local-worker-token

LOG_LEVEL=info
